# ── Python ────────────────────────────────────────────────────────────────────
.venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/

# ── Model artifacts ────────────────────────────────────────────────────────────
# Regenerate with: python scripts/evaluate_models.py
# Saved to demo/models/ by default
models/

# ── Large public datasets ──────────────────────────────────────────────────────
# CW.npz (~500 MB) — download from https://zenodo.org/records/13732130
data/*.npz
data/*.gz
data/*.csv

# ── Collected training data ────────────────────────────────────────────────────
# Regenerate with: python scripts/collect/collect_fresh.py
scripts/collect/dataset.csv
scripts/collect/collection.log

# ── Runtime output ─────────────────────────────────────────────────────────────
# Inference log written by dashboard.py — kept out of git, analyze with analyze_log.py
logs/inference_log.jsonl
scripts/evaluation_results.txt

# ── Defense proxy model cache ──────────────────────────────────────────────────
# Trained by dataset_manager.py from local pcap files
scripts/models/

# ── Packet captures ────────────────────────────────────────────────────────────
*.pcap
*.pcapng
scripts/data/

# ── Streamlit ─────────────────────────────────────────────────────────────────
.streamlit/
